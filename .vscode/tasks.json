        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "PlatformIO: Monitor with log",
      "type": "shell",
      "command": "${workspaceFolder}/.devenvironment/monitor-log.sh",
      "problemMatcher": [],
