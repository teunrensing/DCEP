    {
      "label": "PlatformIO: Ports",
      "type": "shell",
      "command": "pio",
      "args": [
        "device",
        "list"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Static Analysis: PlatformIO Check",
      "type": "shell",
      "command": "pio",
      "args": [
        "check",
        "--fail-on-defect",
        "medium"
      ],
      "group": "test",
      "problemMatcher": [
        "$gcc",
        {
          "owner": "clang-tidy",
          "fileLocation": [
            "relative",
            "${workspaceFolder}"
          ],
          "pattern": {
            "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error|note):\\s+(.*?)(?:\\s+\\[(.*)\\])?$",
            "file": 1,
            "line": 2,
            "column": 3,
            "severity": 4,
            "message": 5,
            "code": 6
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Static Analysis: clang-tidy project",
      "type": "shell",
      "command": "${workspaceFolder}/.devenvironment/run-clang-tidy.sh",
      "args": [],
      "group": "test",
      "problemMatcher": [
        {
          "owner": "clang-tidy",
          "fileLocation": [
            "relative",
            "${workspaceFolder}"
          ],
          "pattern": {
            "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error|note):\\s+(.*?)(?:\\s+\\[(.*)\\])?$",
            "file": 1,
            "line": 2,
            "column": 3,
            "severity": 4,
            "message": 5,
            "code": 6
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Static Analysis: clang-tidy active file",
      "type": "shell",
      "command": "clang-tidy",
      "args": [
        "${file}",
        "-p",
        "${workspaceFolder}",
        "--config-file=${workspaceFolder}/.clang-tidy"
      ],
      "problemMatcher": [
        {
          "owner": "clang-tidy",
          "fileLocation": [
            "relative",
            "${workspaceFolder}"
          ],
          "pattern": {
            "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error|note):\\s+(.*?)(?:\\s+\\[(.*)\\])?$",
            "file": 1,
            "line": 2,
            "column": 3,
            "severity": 4,
            "message": 5,
            "code": 6
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Static Analysis: clang-tidy project with fixes",
      "type": "shell",
      "command": "${workspaceFolder}/.devenvironment/run-clang-tidy.sh",
      "options": {
        "env": {
          "FIX": "1"
        }
      },
      "problemMatcher": [
        {
          "owner": "clang-tidy",
          "fileLocation": [
            "relative",
            "${workspaceFolder}"
          ],
          "pattern": {
            "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error|note):\\s+(.*?)(?:\\s+\\[(.*)\\])?$",
