{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PlatformIO: Build",
      "type": "shell",
      "command": "pio",
      "args": [
        "run"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "PlatformIO: Upload",
      "type": "shell",
      "command": "pio",
      "args": [
        "run",
        "--target",
        "upload"
      ],
      "dependsOn": "PlatformIO: Build",
      "problemMatcher": [
        "$gcc"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "PlatformIO: Monitor",
      "type": "shell",
      "command": "pio",
      "args": [
        "device",
        "monitor"
      ],
      "problemMatcher": [],
