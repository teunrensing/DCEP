PROJECT_NAME           = "PlatformIO Firmware"
PROJECT_BRIEF          = "Firmware documentation generated with Doxygen"
OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = NO
OUTPUT_LANGUAGE        = English

INPUT                  = README.md docs/DoxygenMainPage.md include src lib test
USE_MDFILE_AS_MAINPAGE = docs/DoxygenMainPage.md
FILE_PATTERNS          = *.c *.cc *.cpp *.cxx *.h *.hh *.hpp *.hxx *.ino *.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */.pio/* */.git/* */build/* */dist/*

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
MULTILINE_CPP_IS_BRIEF = YES

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
WARN_AS_ERROR          = NO
WARN_LOGFILE           = docs/doxygen/doxygen-warnings.log

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES
FULL_SIDEBAR           = NO
GENERATE_LATEX         = NO

MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 4
AUTOLINK_SUPPORT       = YES

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             += \
  ARDUINO=10819 \
  ESP_PLATFORM=1 \
  PROGMEM= \
  PGM_P=const char* \
  IRAM_ATTR= \
  ICACHE_RAM_ATTR= \
  __attribute__(x)= \
  __declspec(x)=

HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
DOT_TRANSPARENT        = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
UML_LOOK               = YES

