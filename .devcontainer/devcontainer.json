{
  "name": "PlatformIO Firmware",
  "initializeCommand": "mkdir -p ${localWorkspaceFolder}/.platformio",
  "postStartCommand": [
    "make compiledb",
    "make init"
  ],
  "build": {
    "dockerfile": "Dockerfile"
  },
  "containerEnv": {
    "DEVENV_TEAM_MODE": "0",
    "PLATFORMIO_CORE_DIR": "/home/vscode/.platformio",
    "CCACHE_DIR": "/home/vscode/.cache/ccache"
  },
  "runArgs": [
    "--privileged"
  ],
  "mounts": [
    "source=/dev/bus/usb,target=/dev/bus/usb,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/.platformio,target=/home/vscode/.platformio,type=bind,consistency=cached",
    "source=ccache-cache,target=/home/vscode/.cache/ccache,type=volume"
  ],
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "platformio.platformio-ide",
        "ms-azuretools.vscode-containers",
        " ms-vscode-remote.remote-containers",
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-vscode.cpptools",
        "marus25.cortex-debug",
        "mcu-debug.debug-tracker-vscode",
        "spmeesseman.vscode-taskexplorer",
        "usernamehw.errorlens",
        "cschlosser.doxdocgen",
        "gruntfuggly.todo-tree",
        "streetsidesoftware.code-spell-checker",
        "yzhang.markdown-all-in-one",
        "mhutchie.git-graph",
        "eamodio.gitlens",
        "ms-vscode.hexeditor",
        "ms-vscode.makefile-tools"
      ],
      "settings": {
        "C_Cpp.intelliSenseEngine": "disabled",
        "todo-tree.ripgrep": "rg",
        "todo-tree.highlights.defaultHighlight": {
          "icon": "alert",
          "type": "text",
          "foreground": "red",
          "background": "white",
          "opacity": 50,
          "iconColour": "blue"
        },
        "todo-tree.highlights.customHighlight": {
          "TODO": {
            "icon": "check",
            "type": "line"
          },
          "FIXME": {
            "foreground": "black",
            "iconColour": "yellow",
            "gutterIcon": true
          }
        },
        "clangd.arguments": [
          "--background-index",
          "--clang-tidy",
          "--compile-commands-dir=${workspaceFolder}",
          "--completion-style=detailed",
          "--header-insertion=never"
        ],
        "editor.formatOnSave": true,
        "[c]": {
          "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
        },
        "[cpp]": {
          "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
        }
      }
    }
  }
}
