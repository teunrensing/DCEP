# Common debug probes and USB serial adapters for PlatformIO development.
# Install with: make udev-rules

# ST-Link / STMicroelectronics
SUBSYSTEM=="usb", ATTR{idVendor}=="0483", MODE="0666", GROUP="plugdev", TAG+="uaccess"

# SEGGER J-Link
SUBSYSTEM=="usb", ATTR{idVendor}=="1366", MODE="0666", GROUP="plugdev", TAG+="uaccess"

# CMSIS-DAP / DAPLink
SUBSYSTEM=="usb", ATTR{idVendor}=="0d28", MODE="0666", GROUP="plugdev", TAG+="uaccess"

# Espressif USB/JTAG and serial
SUBSYSTEM=="usb", ATTR{idVendor}=="303a", MODE="0666", GROUP="plugdev", TAG+="uaccess"

# FTDI serial adapters
SUBSYSTEM=="usb", ATTR{idVendor}=="0403", MODE="0666", GROUP="plugdev", TAG+="uaccess"

# Silicon Labs CP210x serial adapters
SUBSYSTEM=="usb", ATTR{idVendor}=="10c4", MODE="0666", GROUP="plugdev", TAG+="uaccess"

# WCH CH340/CH341 serial adapters
SUBSYSTEM=="usb", ATTR{idVendor}=="1a86", MODE="0666", GROUP="plugdev", TAG+="uaccess"

